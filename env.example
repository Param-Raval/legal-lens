# AI Provider: "openai" (default) or "ollama"
AI_PROVIDER=openai

# Azure OpenAI / OpenAI Configuration
OPENAI_BASE_URL=https://your-resource.cognitiveservices.azure.com/openai/v1/
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=gpt-4o

# Ollama Configuration (fallback)
OLLAMA_BASE_URL=http://localhost:1234
OLLAMA_VISION_MODEL=qwen2.5vl
OLLAMA_REASONING_MODEL=deepseek-r1:8b
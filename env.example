# AI Provider: "openai" (Azure GPT-4o) or "ollama" (local)
AI_PROVIDER=openai

# Azure OpenAI (GPT-4o) — required when AI_PROVIDER=openai
GPT4O_ENDPOINT="https://<your-resource>.cognitiveservices.azure.com/openai/v1/"
GPT4O_DEPLOYMENT="gpt-4o"
GPT4O_API_KEY=""

# Ollama — required when AI_PROVIDER=ollama (local development only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl
OLLAMA_REASONING_MODEL=deepseek-r1:8b